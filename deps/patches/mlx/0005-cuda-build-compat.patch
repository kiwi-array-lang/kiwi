+#include "mlx/fast_primitives.h"
+#include "mlx/primitives.h"
+
+#include <stdexcept>
+
+namespace mlx::core {
+namespace {
+[[noreturn]] void throw_disabled_quantized_cuda() {
+  throw std::runtime_error(
+      "[kiwi_runtime] MLX CUDA quantized and FP8 kernels are not included "
+      "in this build.");
+}
+} // namespace
+
+void QuantizedMatmul::eval_gpu(const std::vector<array>&, array&) {
+  throw_disabled_quantized_cuda();
+}
+
+void GatherQMM::eval_gpu(const std::vector<array>&, array&) {
+  throw_disabled_quantized_cuda();
+}
+
+void QQMatmul::eval_gpu(const std::vector<array>&, array&) {
+  throw_disabled_quantized_cuda();
+}
+
+namespace fast {
+
+void Quantize::eval_gpu(
+    const std::vector<array>&,
+    std::vector<array>&) {
+  throw_disabled_quantized_cuda();
+}
+
+void ConvertFP8::eval_gpu(
+    const std::vector<array>&,
+    std::vector<array>&) {
+  throw_disabled_quantized_cuda();
+}
+} // namespace fast
+} // namespace mlx::core
