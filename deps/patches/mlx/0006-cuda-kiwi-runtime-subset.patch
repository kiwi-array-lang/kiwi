diff --git a/mlx/backend/cuda/kiwi_disabled_runtime.cpp b/mlx/backend/cuda/kiwi_disabled_runtime.cpp
new file mode 100644
--- /dev/null
+++ b/mlx/backend/cuda/kiwi_disabled_runtime.cpp
@@ -0,0 +1,54 @@
+#include "mlx/distributed/primitives.h"
+#include "mlx/primitives.h"
+
+#include <stdexcept>
+#include <string>
+
+namespace mlx::core {
+namespace {
+[[noreturn]] void throw_disabled_cuda_primitive(const char* primitive) {
+  throw std::runtime_error(
+      std::string("[kiwi_runtime] MLX CUDA primitive is not included in this "
+                  "build: ") +
+      primitive);
+}
+} // namespace
+
+void FFT::eval_gpu(const std::vector<array>&, array&) {
+  throw_disabled_cuda_primitive("FFT");
+}
+
+void Hadamard::eval_gpu(const std::vector<array>&, array&) {
+  throw_disabled_cuda_primitive("Hadamard");
+}
+
+void LogSumExp::eval_gpu(const std::vector<array>&, array&) {
+  throw_disabled_cuda_primitive("LogSumExp");
+}
+
+void RandomBits::eval_gpu(const std::vector<array>&, array&) {
+  throw_disabled_cuda_primitive("RandomBits");
+}
+
+namespace distributed {
+
+void AllReduce::eval_gpu(
+    const std::vector<array>&,
+    std::vector<array>&) {
+  throw_disabled_cuda_primitive("AllReduce");
+}
+
+void AllGather::eval_gpu(
+    const std::vector<array>&,
+    std::vector<array>&) {
+  throw_disabled_cuda_primitive("AllGather");
+}
+
+void ReduceScatter::eval_gpu(
+    const std::vector<array>&,
+    std::vector<array>&) {
+  throw_disabled_cuda_primitive("ReduceScatter");
+}
+
+} // namespace distributed
+} // namespace mlx::core
+} // namespace mlx::core
