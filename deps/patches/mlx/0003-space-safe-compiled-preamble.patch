diff --git a/mlx/backend/metal/make_compiled_preamble.sh b/mlx/backend/metal/make_compiled_preamble.sh
index 68aefb0f..714f2e70 100644
--- a/mlx/backend/metal/make_compiled_preamble.sh
+++ b/mlx/backend/metal/make_compiled_preamble.sh
@@ -51,24 +51,33 @@ if [ -n "$HDRS" ]; then
 fi
 
 # Remove any included system frameworks (for MetalPerformancePrimitive headers)
-HDRS=$(echo "$HDRS" | grep -v "Xcode")
+declare -a HDRS_LINES=()
+while IFS= read -r line; do
+  HDRS_LINES+=("$line")
+done < <(
+  printf '%s\n' "$HDRS" |
+  grep -v "Xcode"
+)
 
-# Use the header depth to sort the files in order of inclusion
-declare -a HDRS_LIST=($HDRS)
+# Use the header depth to sort the files in order of inclusion.
+# The compiler output is one header per line with a leading dot-prefix depth
+# marker, e.g. ". /path/to/header.h". We must preserve paths verbatim because
+# paths may contain spaces.
 declare -a HDRS_STACK=()
 declare -a HDRS_SORTED=()
 
-length=${#HDRS_LIST[@]}
+length=${#HDRS_LINES[@]}
 
-HDRS_LIST+=(".")
-
-for ((i=0; i<${length}; i+=2));
-do 
+for ((i=0; i<${length}; i++));
+do
+  line_this="${HDRS_LINES[$i]}"
+  line_next="${HDRS_LINES[$((i + 1))]:-.}"
 
-  header="${HDRS_LIST[$i+1]#$SRC_DIR/}"
+  str_this="${line_this%% *}"
+  str_next="${line_next%% *}"
 
-  str_this="${HDRS_LIST[$i]}"
-  str_next="${HDRS_LIST[$i + 2]}"
+  header_path="${line_this#* }"
+  header="${header_path#$SRC_DIR/}"
 
   depth_this=${#str_this}
   depth_next=${#str_next}
